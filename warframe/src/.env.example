# Copy this to .env.local and fill in your Supabase project values.
# NEVER commit .env.local to the repo.

# Found in your Supabase project: Settings > API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Used only in server-side / admin scripts — never expose in the frontend build
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
